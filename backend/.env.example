# Copy to .env for local dev. See docs/adr/0003-secrets-management.md for
# the production posture (this file's pattern is dev-only).

NODE_ENV=development
LOG_LEVEL=info
SERVICE_NAME=payment-orchestrator

# HTTP
API_HOST=0.0.0.0
API_PORT=3000

# Postgres
DATABASE_URL=postgres://orchestrator:orchestrator@localhost:5432/orchestrator

# Redis
REDIS_URL=redis://localhost:6379

# Hatchet (self-hosted, see docker-compose.yml)
HATCHET_CLIENT_TOKEN=changeme-generated-by-hatchet-setup
HATCHET_CLIENT_TLS_STRATEGY=none

# Stripe — sandbox (test mode) keys only, never live keys in .env.
# See docs/adr/0005-sandbox-production-mode.md: STRIPE_MODE must match
# the key prefixes (sk_test_/pk_test_ for sandbox, sk_live_/pk_live_ for
# production) or the process refuses to boot. Production credentials are
# resolved per psp_account row via secret_ref/publishable_key_ref/
# webhook_secret_ref (ADR-0003), never via these env vars.
STRIPE_MODE=sandbox
STRIPE_SECRET_KEY=sk_test_changeme
STRIPE_PUBLISHABLE_KEY=pk_test_changeme
STRIPE_WEBHOOK_SECRET=whsec_changeme
STRIPE_API_VERSION=2026-06-24.dahlia

# Solidgate — the second PSP (Milestone 8, T8.5/ADR-0011). All optional;
# leave unset if this deployment doesn't use Solidgate. Public/Secret
# keys have the api_pk_/api_sk_ prefix; Webhook keys have wh_pk_/wh_sk_
# (a separate pair — see docs.solidgate.com/payments/integrate/access-to-api).
SOLIDGATE_MODE=sandbox
# SOLIDGATE_PUBLIC_KEY=api_pk_changeme
# SOLIDGATE_SECRET_KEY=api_sk_changeme
# SOLIDGATE_WEBHOOK_PUBLIC_KEY=wh_pk_changeme
# SOLIDGATE_WEBHOOK_SECRET_KEY=wh_sk_changeme
# SOLIDGATE_API_BASE_URL=https://pay.solidgate.com/api/v1

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=payment-orchestrator

# Metrics
METRICS_PORT=9464
