{
  "name": "payment-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev:api": "tsx watch src/api/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start:api": "node dist/api/server.js",
    "start:worker": "node dist/worker.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run test/unit test/contract",
    "test:unit": "vitest run test/unit",
    "test:contract": "vitest run test/contract",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest",
    "migrate": "node-pg-migrate --migrations-dir db/migrations --envPath .env create",
    "migrate:up": "node-pg-migrate up --migrations-dir db/migrations --envPath .env",
    "migrate:down": "node-pg-migrate down --migrations-dir db/migrations --envPath .env",
    "migrate:redo": "node-pg-migrate redo --migrations-dir db/migrations --envPath .env",
    "db:codegen": "kysely-codegen --out-file src/db/types.generated.ts",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@hatchet-dev/typescript-sdk": "^1.24.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "kysely": "^0.29.2",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "stripe": "^22.3.0",
    "uuidv7": "^1.0.2",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "fast-check": "^3.23.1",
    "kysely-codegen": "^0.17.0",
    "node-pg-migrate": "^7.9.1",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
